# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Frontend ---
# URL of the Flask backend (REST API)
API_BASE_URL=http://127.0.0.1:5555

# WebSocket URL for real-time events
VUE_APP_WS_URL=ws://127.0.0.1:5001

# Continuous monitoring publisher URL
CONTINUOUS_PUBLISHER_URL=http://127.0.0.1:5555

# IP address of the sensor VM / host
HOST_URL=<YOUR_SENSOR_VM_IP>

# --- Backend (server/) ---
# Strong random JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<REPLACE_WITH_RANDOM_64_CHAR_HEX>

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:<YOUR_DB_PASSWORD>@localhost:5432/network_analyzer

# Internal communication token shared between the sensor agent and the backend.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_TOKEN=<REPLACE_WITH_RANDOM_64_CHAR_HEX>

# Comma-separated list of allowed CORS origins (frontend URL)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
